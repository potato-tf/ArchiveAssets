// Extended upgrades created by Ian Hunter.
// For mission makers, feel free to use my extended upgrades in your missions.
WaveSchedule
{
	LuaScriptFile		"scripts/cowmangler_charge_shot_attribute.lua"
	DisallowUpgrade
	{
		Upgrade		"maxammo primary increased"
		ItemName	"Rocket Jumper"
	}
	DisallowUpgrade
	{
		Upgrade		"maxammo secondary increased"
		ItemName	"Stickybomb Jumper"
	}
	DisallowUpgrade // Both were replaced by '+50% universal afterburn damage bonus' upgrade.
	{
		Upgrade		"weapon burn dmg increased"
		ClassName	"tf_weapon_flamethrower"
		ClassName	"tf_weapon_flaregun"
	}
	DisallowUpgrade // Both were replaced by '+50% universal afterburn damage bonus' upgrade.
	{
		Upgrade		"weapon burn time increased"
		ClassName	"tf_weapon_flamethrower"
		ClassName	"tf_weapon_flaregun"
	}
	DisallowUpgrade // Level 4 faster power charge on the Sydney Sleeper not working.
	{
		Upgrade		"srifle charge rate increased"
		MaxLevel	3
		ItemName	"The Sydney Sleeper"
	}
	DisallowUpgrade // Replaced by 'Repair' upgrade.
	{
		Upgrade		"srifle charge rate increased"
		ItemName	"The Classic"
	}
	DisallowUpgrade // Replaced by 'Repair', 'Black Project' and Fast Food' upgrades.
	{
		Upgrade		"mult_item_meter_charge_rate"
		ItemName	"The Razorback"
		ItemName	"The Thermal Thruster"
		ClassName	"tf_weapon_lunchbox"
	}
	DisallowUpgrade
	{
		Upgrade		"explode_on_ignite"
		IfUpgradePresent
		{
			"weapon burn dmg reduced"	1
		}
		ItemName	"The Gas Passer"
	}
	DisallowUpgrade
	{
		Upgrade		"weapon burn dmg reduced"
		IfUpgradePresent
		{
			"explode_on_ignite"		1
		}
		ItemName	"The Gas Passer"
	}
